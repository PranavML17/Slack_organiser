# ---- Slack App (create at https://api.slack.com/apps) ----
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Where Slack redirects after you approve access. Must exactly match
# the Redirect URL you register in the Slack app's OAuth settings.
SLACK_REDIRECT_URI=https://YOUR-DEPLOYED-URL.com/slack/oauth/callback

# ---- Google Cloud service account (Sheets API) ----
# Create a service account, download its JSON key, then either:
#  a) paste the whole JSON as one line here, or
#  b) put the file on disk and set GOOGLE_SERVICE_ACCOUNT_FILE instead.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=
# The spreadsheet you created and shared with the service account's
# email (as Editor). Grab the ID from the sheet's URL.
GOOGLE_SHEET_ID=

# ---- App ----
PORT=3000
# Random long string, used to sign the OAuth state param.
SESSION_SECRET=change-this-to-something-random

# Path to a mounted persistent volume (Railway: your Volume's mount path,
# e.g. /data). Leave blank for local testing — the DB will just live in the
# project folder, which is fine locally but won't survive a redeploy on most hosts.
DATA_DIR=

# How often to scan for new mentions/threads (cron syntax, default: hourly)
MENTION_SCAN_CRON=0 * * * *
# When to check for the day's "Task to do today" message (default: every 15 min, 5am-11am)
TASK_SYNC_CRON=*/15 5-11 * * *
